# کپی کن به .env و مقدار را برای محیطِ خودت تنظیم کن.
# آدرسِ پایه‌ی API. در زمانِ build توسطِ اکسپو درون‌ریزی می‌شود (پیشوندِ EXPO_PUBLIC_ لازم است).
#   dev:    http://localhost:8080
#   deploy: https://<api-domain>   (در داکر با --build-arg EXPO_PUBLIC_API_BASE_URL=... پاس می‌شود)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# اختیاری. اگر تنظیم نشود، از روی apiBaseUrl ساخته می‌شود (http→ws).
# EXPO_PUBLIC_WS_BASE_URL=ws://localhost:8080

# — پرداخت / توزیع —
# پرچمِ نحوه‌ی توزیع. فقط برای buildِ APKِ کافه‌بازار روی «bazaar» بگذار تا خرید از
# طریقِ پرداختِ درون‌برنامه‌ایِ بازار (Poolakey) انجام شود؛ در غیرِ این‌صورت زرین‌پال.
#   وب/PWA:      (تنظیم نکن) → زرین‌پال
#   APKِ بازار:  EXPO_PUBLIC_DISTRIBUTION=bazaar
# EXPO_PUBLIC_DISTRIBUTION=bazaar

# کلیدِ عمومیِ RSAِ برنامه از پنلِ بازار (اطلاعاتِ برنامه → تبِ «پرداختِ درون‌برنامه‌ای»).
# فقط برای buildِ بازار لازم است (کلیدِ عمومی است، محرمانه نیست).
# EXPO_PUBLIC_BAZAAR_RSA_KEY=MIGfMA0GCS...
