{
  "expo": {
    "name": "نودوست",
    "slug": "nodoost",
    "version": "1.0.4",
    "orientation": "portrait",
    "icon": "./assets/logo/app-icon.png",
    "scheme": "nodoost",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0B0910",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nodoost.app"
    },
    "android": {
      "package": "com.nodoost.app",
      "adaptiveIcon": {
        "backgroundColor": "#0B0910",
        "backgroundImage": "./assets/logo/adaptive-icon-background.png",
        "foregroundImage": "./assets/logo/adaptive-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/logo/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B0910",
          "image": "./assets/logo/adaptive-icon-foreground.png",
          "imageWidth": 160,
          "android": {
            "image": "./assets/logo/adaptive-icon-foreground.png",
            "imageWidth": 140
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "برای نمایشِ افرادِ نزدیک، به موقعیتِ مکانی نیاز داریم."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "برای انتخابِ عکسِ پروفایل، به گالریِ تصاویر دسترسی نیاز داریم."
        }
      ],
      "expo-secure-store",
      "./plugins/withBazaarBilling",
      "./plugins/withReleaseSigning"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "distribution": "bazaar",
      "bazaarRsaKey": "MIHNMA0GCSqGSIb3DQEBAQUAA4G7ADCBtwKBrwDiPM2q4rwNENVlOGn0mhAdP3dak+ONWHK4VvoR0AWF8U78EyOtvc5qVCoDAHs7svpgFV/qUioL3L9Ph7rehf+j6hcXlUFXnvjzOWYxGKw/9z9bTrt0SXjX9pNNr63et9ZWz6ANbh5OY3y0XyihcRZyLeRB0BsLAovNcH9em7nMLyroxNNTGCWQfToDYyWhxN0M9Ocy1PbkJquuHowCPxtclK9OwRbyEO9lOGwbcrMCAwEAAQ=="
    }
  }
}